# ─────────────────────────────────────────────────────────────────────────────
# Aegis Secrets Broker — Environment Configuration
# Copy to .env and fill in all required values before starting.
# Generate secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# In production, point at pgBouncer (see docker-compose.prod.yml)
DATABASE_URL=postgresql://broker:changeme@pgbouncer:5432/aegis

# Dev only (direct Postgres, no pooling):
# DATABASE_URL=postgresql://broker:changeme@postgres:5432/aegis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth config ───────────────────────────────────────────────────────────────
# Path to auth.json inside the container (mounted volume)
AUTH_PATH=/config/auth.json

# ── Admin credentials ─────────────────────────────────────────────────────────
# Admin panel login and HTTP Basic auth on /admin/api/*
ADMIN_PASSWORD=changeme

# Session signing secret — random, minimum 32 chars
# Generate: openssl rand -hex 32
SECRET_KEY=changeme-replace-with-random-value

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Global default requests/minute per API key (overridable per team/registry via policy)
RATE_LIMIT_RPM=60

# ── Log destinations ──────────────────────────────────────────────────────────
# Comma-separated list. stdout is always active.
# Options: stdout, s3, siem, splunk, datadog
LOG_DESTINATIONS=stdout

# S3 (audit log archival)
# S3_LOG_BUCKET=my-audit-logs
# S3_LOG_PREFIX=aegis/audit
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# SIEM (generic HTTP ingest endpoint)
# LOG_SIEM_URL=https://siem.example.com/ingest
# LOG_SIEM_TOKEN=

# Splunk HEC
# SPLUNK_HEC_URL=https://splunk:8088
# SPLUNK_HEC_TOKEN=

# Datadog
# DD_API_KEY=
# DD_SITE=datadoghq.com

# ── TLS / Caddy (production only) ─────────────────────────────────────────────
# Used by docker-compose.prod.yml Caddy service for automatic TLS
AEGIS_DOMAIN=aegis.example.com
TLS_EMAIL=ops@example.com

# ── PostgreSQL (docker-compose managed) ───────────────────────────────────────
POSTGRES_DB=aegis
POSTGRES_USER=broker
POSTGRES_PASSWORD=changeme

# ── Backup (production) ───────────────────────────────────────────────────────
# S3 bucket for pg_dump backups (docker-compose.prod.yml backup service)
# BACKUP_S3_BUCKET=my-aegis-backups
# BACKUP_S3_PREFIX=pgdump
# BACKUP_RETAIN_DAYS=30
